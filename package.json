{
  "name": "pressurescope",
  "version": "1.0.0",
  "description": "Monitor de presión ESP32 + ADS1115",
  "main": "electron/main.js",
  "author": "Tu Nombre",
  "scripts": {
    "dev:react": "vite",
    "dev": "concurrently -k \"cross-env NODE_ENV=development npm run dev:react\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.tuempresa.pressurescope",
    "productName": "PressureScope",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerLanguages": ["es_ES"],
      "language": "3082"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "xlsx": "^0.18.5"
  }
}
